generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  firstName               String?
  lastName                String?
  phone                   String?
  address                 String?
  role                    Role                     @default(CUSTOMER)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  storeCredit             Decimal                  @default(0) @db.Decimal(10, 2)
  reservedCreditUpdatedAt DateTime?
  reservedStoreCredit     Decimal                  @default(0) @db.Decimal(10, 2)
  cart                    Cart?
  orders                  Order[]
  creditLog               StoreCreditTransaction[]
  wishlist                Product[]                @relation("UserWishlist")
  addresses               Address[]


  @@map("users")
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String?  // e.g. Home, Office
  fullName  String
  phone         String
  addressLine1  String
  addressLine2  String?
  landmark      String?
  city          String?
  state         String?
  pincode       String?
  isDefault     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("addresses")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("categories")
}

model Product {
  id              String      @id @default(uuid())
  name            String
  slug            String      @unique
  description     String?
  price           Decimal     @db.Decimal(10, 2)
  stock           Int         @default(0)
  images          String[]
  categoryId      String
  isFeatured      Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  isActive        Boolean     @default(true)
  chargeTax       Boolean     @default(true)
  compareAtPrice  Decimal?    @db.Decimal(10, 2)
  costPerItem     Decimal?    @db.Decimal(10, 2)
  outOfStockSince DateTime?
  sku             String?     @unique
  cartItems       CartItem[]
  orderItems      OrderItem[]
  category        Category    @relation(fields: [categoryId], references: [id])
  wishlistedBy    User[]      @relation("UserWishlist")

  @@map("products")
}

model Order {
  id              String        @id @default(uuid())
  userId          String?
  status          OrderStatus   @default(PENDING)
  total           Decimal       @db.Decimal(10, 2)
  razorpayOrderId String?
  paymentId       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  orderNumber     String?       @unique
  guestAddress    String?
  guestEmail      String?
  guestFirstName  String?
  guestLastName   String?
  guestPhone      String?
  storeCreditUsed Decimal       @default(0) @db.Decimal(10, 2)
  razorpayAmount  Decimal       @default(0) @db.Decimal(10, 2)
  refundedAmount  Decimal       @default(0) @db.Decimal(10, 2)
  couponDiscount  Decimal?      @db.Decimal(10, 2)
  discountOnMRP   Decimal?      @db.Decimal(10, 2)
  mrpTotal        Decimal?      @db.Decimal(10, 2)
  shippingAmount  Decimal?      @default(0) @db.Decimal(10, 2)
  allowOutOfStock Boolean       @default(false)
  isManual        Boolean       @default(false)
  notes           String?
  paidAmount      Decimal       @default(0) @db.Decimal(10, 2)
  paymentMethod   PaymentMethod @default(ONLINE)
  paymentStatus   PaymentStatus @default(PENDING)
  stockAdjusted   Boolean       @default(false)
  appliedCoupon   String?
  items           OrderItem[]
  user            User?         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Cart {
  id                 String     @id @default(uuid())
  userId             String     @unique
  abandonedEmailSent Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  items              CartItem[]
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

model DiscountCode {
  id                String    @id @default(uuid())
  email             String?
  phone             String?
  code              String    @unique
  isUsed            Boolean   @default(false)
  createdAt         DateTime  @default(now())
  discountPercent   Int       @default(10)
  expiresAt         DateTime?
  maxDiscountAmount Decimal?  @db.Decimal(10, 2)
  orderId           String?
  usedAt            DateTime?
  usedByEmail       String?
  usedByUserId      String?

  @@index([code])
  @@index([email])
  @@map("discount_codes")
}

model StoreCreditTransaction {
  id           String                     @id @default(uuid())
  userId       String
  amount       Decimal                    @db.Decimal(10, 2)
  reason       String
  referenceId  String?
  adminId      String?
  createdAt    DateTime                   @default(now())
  balanceAfter Decimal                    @db.Decimal(10, 2)
  type         StoreCreditTransactionType
  user         User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([referenceId, type])
  @@index([userId, createdAt(sort: Desc)])
  @@map("store_credit_transactions")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  PAID
  CONFIRMED
}

enum PaymentMethod {
  ONLINE
  CASH
  BANK_TRANSFER
  UPI
  COD
  CUSTOM
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum StoreCreditTransactionType {
  EARNED
  REFUNDED
  SPENT
  ADMIN_ADJUSTMENT
}
